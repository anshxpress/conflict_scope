# ConflictScope Backend Environment Variables
DATABASE_URL=postgresql://postgres:password@localhost:5432/conflictscope
PORT=3001
NODE_ENV=development

# Nominatim Geocoding (no API key needed for OSM Nominatim)
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# Feed check interval in milliseconds (10 minutes = 600000)
FEED_CHECK_INTERVAL=600000

# Upstash Redis (temporary memory cache — NOT primary database)
# Get these from https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here