{
  "name": "conflictscope-backend",
  "version": "1.0.0",
  "description": "ConflictScope - Open Global Conflict Intelligence Backend",
  "type": "module",
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed:infrastructure": "bun run scripts/seed-infrastructure.ts",
    "seed:events": "bun run scripts/seed-events.ts",
    "run:pipeline": "bun run scripts/run-pipeline.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "compromise": "^14.14.0",
    "drizzle-orm": "^0.33.0",
    "elysia": "^1.4.27",
    "natural": "^8.1.1",
    "node-html-parser": "^6.1.13",
    "postgres": "^3.4.4",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "bun-types": "latest",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.5.0",
    "@types/natural": "^6.0.1"
  }
